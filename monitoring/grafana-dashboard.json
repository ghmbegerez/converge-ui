{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source (scrapes converge /metrics)",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Converge Platform — operational dashboard for converge, orchestrator, and UI services",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=~\"converge|orchestrator|ui\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "HTTP Request Rate (converge)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(converge_http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "title": "HTTP Latency p95 (converge)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(converge_http_request_duration_seconds_sum[5m]) / rate(converge_http_request_duration_seconds_count[5m])",
          "legendFormat": "{{method}} {{path}} (avg)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "5xx Error Rate (converge)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(converge_http_errors_total[5m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "title": "Rate Limit Throttled (converge)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "converge_rate_limit_throttled_total",
          "legendFormat": "tenant: {{tenant}}"
        },
        {
          "expr": "converge_rate_limit_throttled_global",
          "legendFormat": "global"
        }
      ]
    },
    {
      "title": "Orchestrator — Job Counts by Status",
      "description": "Scraped from orchestrator /api/v1/metrics (JSON). Requires json-datasource plugin or a Prometheus exporter adapter.",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "options": {
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "orchestrator_jobs_by_status",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Orchestrator — Throughput (jobs/hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "orchestrator_throughput_per_hour"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "jobs/h"
        }
      }
    },
    {
      "title": "Orchestrator — Block Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "orchestrator_block_rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.1, "color": "yellow" },
              { "value": 0.3, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Orchestrator — Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "orchestrator_uptime_seconds"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Orchestrator — Total Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "orchestrator_jobs_total"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["converge", "platform"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Converge Platform",
  "uid": "converge-platform-overview",
  "version": 1
}
